---
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/', label: 'Overview' },
  { href: '/principles', label: 'Design principles' },
  { href: '/v0.1', label: 'v0.1 spec' },
];
---

<header class="site-header">
  <div class="wrap inner">
    <a href="/" class="lockup" aria-label="openclearance home">openclearance</a>
    <nav aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class:list={['navlink', { active: isActive(l.href) }]}>
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
  }
  .inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
  }
  .lockup {
    font-family: var(--mono);
    font-size: 1.02rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    border-bottom: none;
  }
  .lockup:hover { color: var(--accent); }
  nav {
    display: flex;
    gap: 1.4rem;
    font-family: var(--sans);
    font-size: 0.92rem;
  }
  .navlink {
    color: var(--ink-2);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .navlink:hover { color: var(--accent); border-bottom-color: var(--accent-soft); }
  .navlink.active { color: var(--accent); border-bottom-color: var(--accent); }
</style>
