---
import Base from '../../layouts/Base.astro';
import { marked } from 'marked';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

/*
 * The human-readable v0.1 specification.
 *
 * The normative prose lives in the reference engine repo at
 * spec/clearance/v0.1/spec.md and is vendored verbatim into this site at
 * src/spec-prose/v0.1/spec.md. We render that markdown as-is (the
 * published spec prose is authoritative, dashes and all) and only rewrite its
 * relative links so cross-references resolve against the served /v0.1/ paths.
 *
 * The machine artifacts themselves are served byte-for-byte from public/v0.1/.
 */

const specMd = readFileSync(
  join(process.cwd(), 'src/spec-prose/v0.1/spec.md'),
  'utf8',
);

// Rewrite the spec's repo-relative links to the served site paths.
function rewriteLinks(md: string): string {
  return md
    .replace(/\]\(context\.jsonld\)/g, '](/v0.1/context.jsonld)')
    .replace(/\]\(clearance-manifest\.schema\.json\)/g, '](/v0.1/clearance-manifest.schema.json)')
    .replace(/\]\(tier0-envelope\.schema\.json\)/g, '](/v0.1/tier0-envelope.schema.json)')
    .replace(/\]\(advisory-entry\.schema\.json\)/g, '](/v0.1/advisory-entry.schema.json)')
    .replace(/\]\(rules\.md\)/g, '](/v0.1/rules)')
    .replace(/\]\(examples\/\)/g, '](/v0.1/examples/)')
    .replace(
      /\]\(\.\.\/VERSIONING\.md\)/g,
      '](https://github.com/cfpramod/open-museum-mcp/blob/main/spec/clearance/VERSIONING.md)',
    );
}

marked.setOptions({ gfm: true });
const specHtml = marked.parse(rewriteLinks(specMd)) as string;
---

<Base
  title="Clearance Manifest v0.1 · openclearance"
  description="The Clearance Manifest v0.1 specification: a portable, fail-closed, byte-exact rights-clearance artifact for one creative work. Normative prose, JSON-LD context, and JSON Schemas served at permanent paths under /v0.1/."
>
  <section class="wrap">
    <p class="eyebrow">Specification</p>

    <div class="spec-body" set:html={specHtml} />
  </section>

  <section class="wrap">
    <h2 id="machine-files">Machine files</h2>
    <p>
      These are the canonical dereference targets. A manifest references the context by its IRI, so
      these paths are held stable for the life of the version. Download or link them directly.
    </p>

    <ul class="facets">
      <li>
        <span><a href="/v0.1/context.jsonld" class="path">/v0.1/context.jsonld</a> &middot; <span class="muted">JSON-LD context, the sole normative authority for term expansion</span></span>
        <span class="verdict">jsonld</span>
      </li>
      <li>
        <span><a href="/v0.1/clearance-manifest.schema.json" class="path">/v0.1/clearance-manifest.schema.json</a> &middot; <span class="muted">payload JSON Schema</span></span>
        <span class="verdict">schema</span>
      </li>
      <li>
        <span><a href="/v0.1/tier0-envelope.schema.json" class="path">/v0.1/tier0-envelope.schema.json</a> &middot; <span class="muted">Tier 0 envelope JSON Schema</span></span>
        <span class="verdict">schema</span>
      </li>
      <li>
        <span><a href="/v0.1/advisory-entry.schema.json" class="path">/v0.1/advisory-entry.schema.json</a> &middot; <span class="muted">verifier advisory entry JSON Schema</span></span>
        <span class="verdict">schema</span>
      </li>
      <li>
        <span><a href="/v0.1/examples/cc0-accepted.json" class="path">/v0.1/examples/cc0-accepted.json</a> &middot; <span class="muted">conformance example, accepted</span></span>
        <span class="verdict">example</span>
      </li>
      <li>
        <span><a href="/v0.1/examples/deny-unrecognized.json" class="path">/v0.1/examples/deny-unrecognized.json</a> &middot; <span class="muted">conformance example, deny</span></span>
        <span class="verdict">example</span>
      </li>
    </ul>

    <p>
      Companion documents: the <a href="/v0.1/rules">rule registry</a> (frozen rule meanings) and the
      <a href="/v0.1/vocab">vocabulary</a> (the <span class="path">oc:</span> term map).
    </p>
  </section>

  <section class="wrap">
    <h2 id="status">Status and stewardship</h2>

    <p class="lede">Draft, v0.1. Pre 1.0, and may be amended in place before 1.0.</p>

    <dl class="colophon">
      <dt>Steward</dt>
      <dd>Open Museum</dd>

      <dt>Editor</dt>
      <dd>Pramod Prasanth</dd>

      <dt>License</dt>
      <dd>
        Dual license. The spec text and documentation are
        <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a> (reuse with attribution).
        The machine artifacts under <span class="path">/v0.1/</span> (JSON Schemas, the JSON-LD context,
        and examples) are <a href="https://creativecommons.org/publicdomain/zero/1.0/">CC0 1.0</a>
        (public domain, no attribution required).
      </dd>

      <dt>How to cite</dt>
      <dd>
        Open Museum. The Clearance Manifest, v0.1. <span class="path">https://openclearance.org/v0.1/</span>
      </dd>

      <dt>Contact</dt>
      <dd>
        <a href="mailto:contact@openclearance.org">contact@openclearance.org</a>. For proposals, open a
        GitHub issue at
        <a href="https://github.com/cfpramod/open-museum-mcp/issues">github.com/cfpramod/open-museum-mcp</a>
        with the <span class="path">openclearance</span> label.
      </dd>

      <dt>Reference implementation</dt>
      <dd>
        <a href="https://github.com/cfpramod/open-museum-mcp">open-museum-mcp</a>, which emits Tier 0
        manifests today.
      </dd>
    </dl>
  </section>
</Base>

<style>
  /* The rendered spec prose inherits the global document styles (h2, table,
     pre, code, a, blockquote.callout-free). Light scoping below keeps the
     long-form markdown legible without overriding tokens. */
  .spec-body :global(h1) { margin-top: 0; }
  .spec-body :global(h4) {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 1rem;
    margin: 1.6rem 0 0.5rem;
    color: var(--ink);
  }
  .spec-body :global(ul), .spec-body :global(ol) {
    max-width: var(--measure);
    padding-left: 1.4rem;
  }
  .spec-body :global(li) { margin: 0.3rem 0; }
  .spec-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1.4rem 0;
    padding: 0.2rem 0 0.2rem 1.2rem;
    color: var(--ink-2);
    max-width: var(--measure);
  }
  .spec-body :global(td:first-child) { white-space: normal; }

  .colophon {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.5rem 1.4rem;
    max-width: var(--measure);
    margin: 1.4rem 0;
    font-family: var(--sans);
    font-size: 0.96rem;
  }
  .colophon dt {
    font-weight: 600;
    color: var(--ink-3);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding-top: 0.15rem;
  }
  .colophon dd { margin: 0; color: var(--ink-2); }
  @media (max-width: 33rem) {
    .colophon { grid-template-columns: 1fr; gap: 0.15rem; }
    .colophon dt { margin-top: 0.7rem; }
  }
</style>
